{
  "opencollection": "1.0.0",
  "info": {
    "name": "Mews Connector API — Point of Sale Outlets",
    "version": "v1"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "ClientToken",
      "value": "{{ClientToken}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Outlet bills",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Mews Add Outlet Bills",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.mews.com/api/connector/v1/outletBills/add",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Adds new outlet bills with their items."
        }
      ]
    },
    {
      "info": {
        "name": "Outlet items",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Mews Get All Outlet Items",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.mews.com/api/connector/v1/outletItems/getAll",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Returns all outlet items of the enterprise that were consumed (posted) or will be consumed within the specified interval. If the `Currency` is specified, costs of the items are converted to that currency.\nNote this operation uses [Pagination](https://mews-systems.gitbook.io/connector-api/guidelines/pagination/) and supports [Portfolio Access Tokens](https://mews-systems.gitbook.io/connector-api/concepts/multi-property)."
        }
      ]
    },
    {
      "info": {
        "name": "Outlets",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Mews Get All Outlets",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.mews.com/api/connector/v1/outlets/getAll",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Returns all outlets of an enterprise associated with the connector integration."
        }
      ]
    }
  ],
  "bundled": true
}